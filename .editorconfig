# EditorConfig — consistent coding style across editors
# https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{c,h,c.inc,h.inc}]
indent_style = space
indent_size = 4

[*.sh]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[Makefile*]
indent_style = tab
indent_size = 8

[SConscript*]
indent_style = space
indent_size = 4

[SConstruct*]
indent_style = space
indent_size = 4

[*.cmake]
indent_style = space
indent_size = 4

[CMakeLists.txt]
indent_style = space
indent_size = 4

[Kconfig*]
indent_style = tab
indent_size = 8

# Imported scripts keep their original style
[scripts/checkpatch.pl]
indent_style = tab
indent_size = 8
